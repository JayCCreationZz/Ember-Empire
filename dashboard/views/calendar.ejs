<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Ember Empire Battle Calendar</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen">

<div class="max-w-7xl mx-auto p-6">

<h1 class="text-3xl font-bold text-orange-400 mb-6">
🔥 Ember Empire Weekly Battle Schedule
</h1>

<div class="grid grid-cols-7 gap-4">

<% Object.keys(week).forEach(day => { %>

<div class="bg-gray-800 rounded-xl p-4 shadow">

<h2 class="text-orange-400 font-semibold mb-3">
<%= day %>
</h2>

<% week[day].forEach(battle => { %>

<div class="bg-gray-700 rounded p-3 mb-3">

<div class="font-bold text-sm">
<%= battle.time %>
</div>

<div class="text-sm">
<%= battle.host %> vs <%= battle.opponent %>
</div>

<% if(battle.poster){ %>
<img src="<%= battle.poster %>" class="rounded mt-2">
<% } %>

<% if(battle.liveLink){ %>
<a href="<%= battle.liveLink %>"
target="_blank"
class="block mt-2 bg-green-600 text-center py-1 rounded">

▶ Join Live

</a>
<% } %>

</div>

<% }) %>

</div>

<% }) %>

</div>

</div>

</body>
</html>