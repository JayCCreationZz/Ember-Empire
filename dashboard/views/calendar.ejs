<!DOCTYPE html>
<html>
<head>
<title>Battle Calendar</title>
<script src="https://cdn.tailwindcss.com"></script>

<style>

.section-title{
font-size:26px;
margin-top:30px;
margin-bottom:10px;
font-weight:bold;
}

.poster{
border-radius:14px;
max-height:200px;
object-fit:cover;
}

.badge{
padding:3px 8px;
border-radius:6px;
font-size:12px;
margin-left:6px;
}

.live{ background:red; }
.soon{ background:orange; }

</style>
</head>

<body class="bg-slate-900 text-white">

<div class="max-w-7xl mx-auto px-6 py-10">


<!-- NAV -->

<div class="flex justify-between mb-8">

<h1 class="text-3xl font-bold">Battle Calendar 📅</h1>

<div class="flex gap-3">
<a href="/dashboard" class="bg-slate-700 px-5 py-2 rounded-xl">Dashboard</a>
<a href="/calendar" class="bg-orange-500 px-5 py-2 rounded-xl">Calendar</a>
<a href="/logout" class="bg-red-600 px-5 py-2 rounded-xl">Logout</a>
</div>

</div>


<% battles.forEach(b=>{ %>

<div class="bg-slate-800 p-4 rounded mb-6">

<img src="/poster/<%= b.id %>?t=<%= Date.now() %>"
class="poster mb-3">

<h3>

🔥 <%= b.hostName || b.host %> vs <%= b.opponent %>

<% if(b.status==="live"){ %>
<span class="badge live">LIVE 🔴</span>
<% } %>

<% if(b.status==="soon"){ %>
<span class="badge soon">Starting Soon ⏳</span>
<% } %>

</h3>

<p>📅 <%= b.date %></p>
<p>⏰ <%= b.time %></p>

<% if(b.livelink){ %>
<a href="<%= b.livelink %>" target="_blank"
class="text-orange-400 underline">
Watch Battle
</a>
<% } %>

</div>

<% }) %>

</div>

</body>
</html>