<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Ember Empire Login</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>

body{
background:radial-gradient(circle at center,
#020617,
#0f172a);
}

.logo{
animation:pulseGlow 2.5s infinite ease-in-out;
}

@keyframes pulseGlow{

0%{
filter:drop-shadow(0 0 6px rgba(255,120,0,.5));
}

50%{
filter:
drop-shadow(0 0 18px rgba(255,120,0,.9))
drop-shadow(0 0 40px rgba(255,60,0,.5));
}

100%{
filter:drop-shadow(0 0 6px rgba(255,120,0,.5));
}

}

.card{
background:rgba(30,41,59,.85);
backdrop-filter:blur(12px);
border-radius:18px;
box-shadow:
0 0 25px rgba(255,120,0,.25);
}

</style>

</head>

<body class="flex items-center justify-center min-h-screen text-white">

<div class="card p-10 text-center">

<img
src="/logo.png"
class="logo w-28 mx-auto mb-6">

<h1 class="text-3xl font-bold text-orange-400 mb-6">

Ember Empire Dashboard

</h1>

<a href="/login"

class="bg-orange-500 hover:bg-orange-600 px-8 py-3 rounded-xl shadow-lg text-lg">

Login with Discord

</a>

</div>

</body>
</html>