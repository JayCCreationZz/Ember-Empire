<!DOCTYPE html>
<html>
<head>

<title>Ember Empire Control Panel</title>
<link rel="icon" href="/favicon.png">

<style>

body {
    font-family: Arial;
    background: #0c0c0c;
    color: white;
    margin: 0;
}

/* HEADER */

.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #141414;
    padding: 20px 40px;
    border-bottom: 1px solid #1f1f1f;
}

.brand {
    display: flex;
    align-items: center;
    gap: 14px;
}

/* EMBER LOGO */

.logo {
    height: 52px;
    animation: emberGlow 3s ease-in-out infinite alternate;
}

.logo:hover {
    transform: scale(1.08);
}

@keyframes emberGlow {

    0% {
        filter:
        drop-shadow(0 0 4px rgba(255,120,0,0.4));
    }

    50% {
        filter:
        drop-shadow(0 0 12px rgba(255,140,0,0.7));
    }

    100% {
        filter:
        drop-shadow(0 0 6px rgba(255,80,0,0.5));
    }

}

.header h1 {
    margin: 0;
    color: #ff7a18;
}

.role-badge {
    padding: 6px 12px;
    border-radius: 6px;
    background: #1f1f1f;
    font-size: 14px;
}

/* CONTAINER */

.container {
    max-width: 1100px;
    margin: auto;
    padding: 40px;
}

/* CARD */

.card {
    background: #161616;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 25px;
}

.card h2 {
    margin-top: 0;
    color: #ff7a18;
}

/* INPUTS */

input {
    padding: 10px;
    margin: 6px 4px;
    border-radius: 6px;
    border: none;
    background: #222;
    color: white;
}

/* BUTTONS */

button {
    padding: 10px 18px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-weight: 600;
}

.btn-create { background: #ff7a18; }
.btn-update { background: #2e8cff; }
.btn-delete { background: #c0392b; }

/* BATTLE CARD */

.battle-card {
    display: flex;
    gap: 20px;
    background: #1c1c1c;
    border-radius: 10px;
    padding: 18px;
    margin-top: 18px;
}

/* POSTER IMAGE */

.poster {
    width: 140px;
    border-radius: 8px;
    object-fit: cover;
}

/* BATTLE CONTENT */

.battle-content {
    flex: 1;
}

.meta {
    opacity: .7;
    margin-top: 5px;
}

.live-link {
    display: inline-block;
    margin-top: 8px;
    padding: 6px 12px;
    background: #ff7a18;
    border-radius: 5px;
    text-decoration: none;
    color: white;
}

/* LOGOUT */

.logout {
    color: white;
    text-decoration: none;
}

</style>

</head>

<body>

<div class="header">

<div class="brand">

<img src="/logo.png" class="logo">

<h1>Ember Empire Control Panel</h1>

</div>

<div>

<span class="role-badge">
Role: <%= roleLevel.toUpperCase() %>
</span>

<a class="logout" href="/logout">Logout</a>

</div>

</div>


<div class="container">


<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="card">

<h2>Create Battle</h2>

<form action="/create" method="POST">

<input name="host" placeholder="Host" required>
<input name="opponent" placeholder="Opponent" required>
<input name="date" placeholder="DD/MM/YYYY" required>
<input name="time" placeholder="HH:MM" required>
<input name="poster" placeholder="Poster URL">
<input name="liveLink" placeholder="Live Link">

<br>

<button class="btn-create">Create Battle</button>

</form>

</div>

<% } %>


<div class="card">

<h2>Scheduled Battles</h2>

<% battles.forEach(battle => { %>

<div class="battle-card">


<% if(battle.poster){ %>

<img src="<%= battle.poster %>" class="poster">

<% } %>


<div class="battle-content">

<strong>
<%= battle.host %> vs <%= battle.opponent %>
</strong>

<div class="meta">
📅 <%= battle.date %> &nbsp;&nbsp; ⏰ <%= battle.time %>
</div>


<% if(battle.liveLink){ %>

<a href="<%= battle.liveLink %>" target="_blank" class="live-link">
Watch Live
</a>

<% } %>


<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<form action="/edit/<%= battle.id %>" method="POST">

<input name="host" value="<%= battle.host %>">
<input name="opponent" value="<%= battle.opponent %>">
<input name="date" value="<%= battle.date %>">
<input name="time" value="<%= battle.time %>">
<input name="poster" value="<%= battle.poster %>">
<input name="liveLink" value="<%= battle.liveLink %>">

<br>

<button class="btn-update">Update</button>

</form>

<% } %>


<% if(roleLevel === "owner"){ %>

<form action="/delete/<%= battle.id %>" method="POST">

<button class="btn-delete">
Delete Battle
</button>

</form>

<% } %>


</div>

</div>

<% }) %>

</div>

</div>

</body>
</html>