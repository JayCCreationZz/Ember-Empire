<!DOCTYPE html>
<html>
<head>
    <title>Ember Empire Dashboard</title>

    <style>
        body {
            font-family: Arial;
            background: #0e0e0e;
            color: white;
            padding: 30px;
        }

        h1 {
            color: orange;
        }

        .battle {
            background: #1f1f1f;
            padding: 10px;
            margin: 8px 0;
            border-radius: 6px;
        }

        input {
            padding: 5px;
            margin: 3px;
        }

        button {
            padding: 6px 10px;
            background: orange;
            border: none;
            cursor: pointer;
        }

        form {
            margin-bottom: 20px;
        }
    </style>
</head>

<body>

<h1>
🔥 Ember Empire Dashboard
<a href="/logout" style="float:right;color:white;">Logout</a>
</h1>

<p>
Logged in as:
<strong><%= roleLevel.toUpperCase() %></strong>
</p>


<!-- CREATE FORM (Owner + Admin only) -->

<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<h2>Create Battle</h2>

<form action="/create" method="POST">

    Host:
    <input name="host" required>

    Opponent:
    <input name="opponent" required>

    Date (DD/MM/YYYY):
    <input name="date" required>

    Time (HH:MM):
    <input name="time" required>

    Poster URL:
    <input name="poster">

    Live Link:
    <input name="liveLink">

    <button type="submit">Create</button>

</form>

<% } %>


<h2>Scheduled Battles</h2>

<% battles.forEach(battle => { %>

<div class="battle">

<strong>
<%= battle.host %> vs <%= battle.opponent %>
</strong>

<br>
Date: <%= battle.date %>
<br>
Time: <%= battle.time %>

<% if (battle.liveLink) { %>
<br>
<a href="<%= battle.liveLink %>" target="_blank">
Watch Live
</a>
<% } %>


<!-- EDIT BUTTON (Owner + Admin) -->

<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<form action="/edit/<%= battle.id %>" method="POST">

    Host:
    <input name="host" value="<%= battle.host %>">

    Opponent:
    <input name="opponent" value="<%= battle.opponent %>">

    Date:
    <input name="date" value="<%= battle.date %>">

    Time:
    <input name="time" value="<%= battle.time %>">

    Poster:
    <input name="poster" value="<%= battle.poster %>">

    Live:
    <input name="liveLink" value="<%= battle.liveLink %>">

    <button type="submit">Update</button>

</form>

<% } %>


<!-- DELETE BUTTON (Owner only) -->

<% if (roleLevel === "owner") { %>

<form action="/delete/<%= battle.id %>" method="POST">
    <button type="submit">Delete</button>
</form>

<% } %>

</div>

<% }) %>

</body>
</html>