<!DOCTYPE html>
<html>
<head>
<title>Ember Empire Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>

<style>

body{
background:linear-gradient(135deg,#020617,#0f172a);
color:white;
}

.logo{
animation:pulseGlow 2.2s infinite ease-in-out;
}

@keyframes pulseGlow{
0%{filter:drop-shadow(0 0 10px rgba(255,120,0,.5));}
50%{
filter:
drop-shadow(0 0 28px rgba(255,120,0,.95))
drop-shadow(0 0 50px rgba(255,60,0,.5));
}
100%{filter:drop-shadow(0 0 10px rgba(255,120,0,.5));}
}

.card{
background:rgba(30,41,59,.75);
backdrop-filter:blur(12px);
border-radius:18px;
border:1px solid rgba(255,120,0,.25);
}

.poster{
border-radius:12px;
max-height:200px;
object-fit:cover;
}

.badge{
padding:3px 8px;
border-radius:6px;
font-size:12px;
margin-right:6px;
}

.live{ background:red; }
.soon{ background:orange; }

.rule{ background:#1e293b; }

</style>
</head>

<body>

<div class="max-w-7xl mx-auto px-6 py-10">


<!-- HEADER -->

<div class="flex justify-between items-center mb-10">

<div class="flex items-center gap-4">
<img src="/logo.png" class="logo w-14">
<h1 class="text-3xl font-bold">Ember Empire Dashboard 🔥</h1>
</div>

<div class="flex gap-3">
<a href="/dashboard" class="bg-slate-700 px-5 py-2 rounded-xl">Dashboard</a>
<a href="/calendar" class="bg-orange-500 px-5 py-2 rounded-xl">Calendar 📅</a>
<a href="/logout" class="bg-red-600 px-5 py-2 rounded-xl">Logout</a>
</div>

</div>


<!-- CREATE PANEL -->

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="card p-6 mb-10">

<h2 class="text-xl font-semibold mb-4">Create Battle ⚔️</h2>

<form action="/create" method="POST" enctype="multipart/form-data"
class="grid md:grid-cols-2 gap-4">

<select name="host" required onchange="setHostName(this)"
class="text-black p-2 rounded">

<option value="">Select Host</option>

<% agencyMembers.forEach(member=>{ %>
<option value="<%= member.id %>"><%= member.name %></option>
<% }) %>

</select>

<input type="hidden" name="hostName" id="hostNameField">

<input name="opponent" placeholder="Opponent username"
required class="text-black p-2 rounded">

<input name="date" placeholder="DD/MM/YYYY"
required class="text-black p-2 rounded">

<input name="time" placeholder="HH:MM"
required class="text-black p-2 rounded">

<input name="liveLink"
placeholder="Live link"
class="text-black p-2 rounded col-span-2">

<label><input type="checkbox" name="managerGifting" value="true"> Manager gifting</label>
<label><input type="checkbox" name="adultOnly" value="true"> 18+</label>
<label><input type="checkbox" name="powerUps" value="true"> Powerups</label>
<label><input type="checkbox" name="noHammers" value="true"> No hammers</label>

<input type="file" name="poster" class="col-span-2">

<button class="bg-orange-500 px-5 py-2 rounded col-span-2">
Create Battle 🚀
</button>

</form>

</div>

<% } %>


<!-- BATTLES GRID -->

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(b=>{ %>

<div class="card p-5">

<img src="/poster/<%= b.id %>?t=<%= Date.now() %>"
class="poster mb-4">

<h3 class="text-lg text-orange-400 font-semibold">

🔥 <%= b.hostName || b.host %> vs <%= b.opponent %>

<% if(b.status==="live"){ %>
<span class="badge live">LIVE 🔴</span>
<% } %>

<% if(b.status==="soon"){ %>
<span class="badge soon">Starting Soon ⏳</span>
<% } %>

</h3>


<div class="mt-2">

<% if(b.managergifting){ %>
<span class="badge rule">Manager gifting</span>
<% } %>

<% if(b.adultonly){ %>
<span class="badge rule">18+</span>
<% } %>

<% if(b.powerups){ %>
<span class="badge rule">Powerups</span>
<% } %>

<% if(b.nohammers){ %>
<span class="badge rule">No hammers</span>
<% } %>

</div>


<p class="mt-2">📅 <%= b.date %></p>
<p>⏰ <%= b.time %></p>


<% if(b.livelink){ %>
<a href="<%= b.livelink %>" target="_blank"
class="text-orange-400 underline">
Watch Battle
</a>
<% } %>


<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<form action="/delete/<%= b.id %>" method="POST" class="mt-3">
<button class="bg-red-600 px-3 py-1 rounded">
Delete
</button>
</form>

<form action="/replace-poster/<%= b.id %>"
method="POST" enctype="multipart/form-data"
class="mt-2">

<input type="file" name="poster">
<button class="bg-slate-600 px-3 py-1 rounded mt-1">
Replace Poster
</button>

</form>

<% } %>

</div>

<% }) %>

</div>

</div>


<script>

function setHostName(select){
const selectedText =
select.options[select.selectedIndex].text;
document.getElementById("hostNameField").value =
selectedText;
}

</script>

</body>
</html>