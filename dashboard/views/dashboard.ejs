<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ember Empire Dashboard</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
body{
background:linear-gradient(135deg,#020617,#0f172a);
}

/* glow card styling */
.card{
background:rgba(30,41,59,.75);
backdrop-filter:blur(12px);
border-radius:18px;
border:1px solid rgba(255,120,0,.2);
transition:.25s ease;
}

.card:hover{
transform:translateY(-4px);
box-shadow:
0 0 20px rgba(255,120,0,.45),
0 0 40px rgba(255,60,0,.25);
}

.poster-thumb{
border-radius:12px;
max-height:160px;
object-fit:cover;
}
</style>
</head>

<body class="text-white min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10 relative z-0">

<!-- HEADER -->
<div class="flex items-center justify-between mb-10 relative z-50">

<div class="flex items-center gap-4">

<img
src="/logo.png"
class="w-14 h-14 drop-shadow-[0_0_14px_rgba(255,90,0,0.75)]"
/>

<h1 class="text-3xl font-bold">
Ember Empire Dashboard
</h1>

</div>


<!-- DROPDOWN MENU -->
<div class="relative z-50">

<button
onclick="toggleMenu()"
class="bg-orange-500 hover:bg-orange-600 px-5 py-2 rounded-xl shadow-lg transition"
>
Menu ☰
</button>

<div
id="dropdownMenu"
class="hidden absolute right-0 mt-3 w-56 bg-gray-900 rounded-xl shadow-xl border border-orange-500/30 overflow-hidden z-50"
>

<a href="/dashboard"
class="block px-4 py-3 hover:bg-orange-500/20">
⚔ Dashboard
</a>

<a href="/calendar"
class="block px-4 py-3 hover:bg-orange-500/20">
📅 Calendar
</a>

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<a href="#createBattle"
class="block px-4 py-3 hover:bg-orange-500/20">
➕ Create Battle
</a>

<% } %>

<% if(roleLevel === "owner"){ %>

<a href="#manageBattles"
class="block px-4 py-3 hover:bg-orange-500/20">
🛠 Manage Battles
</a>

<% } %>

<a href="/logout"
class="block px-4 py-3 hover:bg-red-500/30">
🚪 Logout
</a>

</div>
</div>

</div>


<!-- CREATE BATTLE PANEL -->
<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div id="createBattle" class="card p-6 mb-12">

<h2 class="text-2xl font-semibold mb-5">
Create Battle
</h2>

<form
action="/create"
method="POST"
enctype="multipart/form-data"
class="grid md:grid-cols-2 gap-4"
>

<input
name="host"
placeholder="Host"
required
class="bg-gray-800 p-3 rounded-lg"
/>

<input
name="opponent"
placeholder="Opponent"
required
class="bg-gray-800 p-3 rounded-lg"
/>

<input
name="date"
placeholder="DD/MM/YYYY"
required
class="bg-gray-800 p-3 rounded-lg"
/>

<input
name="time"
placeholder="HH:MM"
required
class="bg-gray-800 p-3 rounded-lg"
/>

<input
name="liveLink"
placeholder="Live link (optional)"
class="bg-gray-800 p-3 rounded-lg md:col-span-2"
/>

<input
type="file"
name="poster"
accept="image/*"
class="bg-gray-800 p-3 rounded-lg md:col-span-2"
/>

<button
class="bg-orange-500 hover:bg-orange-600 py-3 rounded-lg md:col-span-2"
>
Create Battle
</button>

</form>

</div>

<% } %>


<!-- SCHEDULED BATTLES -->
<div id="manageBattles">

<h2 class="text-2xl font-semibold mb-6">
Scheduled Battles
</h2>

<% if(!battles.length){ %>

<div class="text-gray-400">
No battles scheduled yet ⚔
</div>

<% } else { %>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(battle=>{ %>

<div class="card p-5">

<% if(battle.poster){ %>

<img
src="<%= battle.poster %>"
class="poster-thumb mb-4"
/>

<% } %>

<h3 class="text-lg font-semibold text-orange-400">
🔥 <%= battle.host %> vs <%= battle.opponent %>
</h3>

<p class="text-gray-300">
📅 <%= battle.date %>
</p>

<p class="text-gray-300 mb-2">
⏰ <%= battle.time %>
</p>

<% if(battle.liveLink){ %>

<a
href="<%= battle.liveLink %>"
target="_blank"
class="inline-block bg-orange-500 hover:bg-orange-600 px-3 py-2 rounded-lg mb-3"
>
Watch Battle 🔗
</a>

<% } %>


<!-- OWNER DELETE BUTTON -->
<% if(roleLevel === "owner"){ %>

<form
action="/delete/<%= battle.id %>"
method="POST"
>

<button
class="bg-red-600 hover:bg-red-700 px-3 py-2 rounded-lg"
>
Delete Battle
</button>

</form>

<% } %>

</div>

<% }) %>

</div>

<% } %>

</div>

</div>


<script>
function toggleMenu(){
const menu=document.getElementById("dropdownMenu");
menu.classList.toggle("hidden");
}

window.onclick=function(event){
if(!event.target.closest(".relative")){
const menu=document.getElementById("dropdownMenu");
if(menu) menu.classList.add("hidden");
}
}
</script>

</body>
</html>