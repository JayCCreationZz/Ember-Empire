<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ember Empire Dashboard</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
body{
background:linear-gradient(135deg,#020617,#0f172a);
}

.card{
background:rgba(30,41,59,.75);
backdrop-filter:blur(12px);
border-radius:18px;
border:1px solid rgba(255,120,0,.2);
transition:.25s ease;
}

.card:hover{
transform:translateY(-4px);
box-shadow:
0 0 20px rgba(255,120,0,.45),
0 0 40px rgba(255,60,0,.25);
}

.poster-thumb{
border-radius:12px;
max-height:160px;
object-fit:cover;
}
</style>
</head>

<body class="text-white min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10 relative z-0">

<!-- HEADER -->
<div class="flex items-center justify-between mb-10">

<div class="flex items-center gap-4">

<img src="/logo.png"
class="w-14 h-14 drop-shadow-[0_0_14px_rgba(255,90,0,0.75)]">

<h1 class="text-3xl font-bold">
Ember Empire Dashboard
</h1>

</div>

<a href="/calendar"
class="bg-orange-500 hover:bg-orange-600 px-5 py-2 rounded-xl shadow-lg">
Calendar 📅
</a>

</div>


<!-- CREATE PANEL -->
<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="card p-6 mb-12">

<h2 class="text-2xl font-semibold mb-5">
Create Battle
</h2>

<form action="/create"
method="POST"
enctype="multipart/form-data"
class="grid md:grid-cols-2 gap-4">

<input name="host"
placeholder="Host Discord ID"
required
class="bg-gray-800 p-3 rounded-lg">

<input name="opponent"
placeholder="Opponent TikTok username"
required
class="bg-gray-800 p-3 rounded-lg">

<input name="date"
type="date"
required
class="bg-gray-800 p-3 rounded-lg">

<input name="time"
type="time"
required
class="bg-gray-800 p-3 rounded-lg">

<input name="liveLink"
placeholder="Live link (optional)"
class="bg-gray-800 p-3 rounded-lg md:col-span-2">

<input type="file"
name="poster"
accept="image/*"
class="bg-gray-800 p-3 rounded-lg md:col-span-2">

<button
class="bg-orange-500 hover:bg-orange-600 py-3 rounded-lg md:col-span-2">

Create Battle

</button>

</form>

</div>

<% } %>


<!-- BATTLES GRID -->
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(battle=>{ %>

<div class="card p-5">

<img
src="/poster/<%= battle.id %>?t=<%= Date.now() %>"
class="poster-thumb mb-4">

<h3 class="text-lg font-semibold text-orange-400">

🔥 <%= battle.host %> vs <%= battle.opponent %>

</h3>

<p class="text-gray-300">
📅 <%= battle.date %>
</p>

<p class="text-gray-300 mb-2">
⏰ <%= battle.time %>
</p>

<% if(battle.liveLink){ %>

<a href="<%= battle.liveLink %>"
target="_blank"
class="inline-block bg-orange-500 hover:bg-orange-600 px-3 py-2 rounded-lg mb-3">

Watch Battle 🔗

</a>

<% } %>

<% if(roleLevel === "owner"){ %>

<form action="/delete/<%= battle.id %>"
method="POST">

<button
class="bg-red-600 hover:bg-red-700 px-3 py-2 rounded-lg">

Delete Battle

</button>

</form>

<% } %>

</div>

<% }) %>

</div>

</div>

</body>
</html>