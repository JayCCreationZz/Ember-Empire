<!DOCTYPE html>
<html>
<head>
    <title>Ember Empire Dashboard</title>

    <style>
        body {
            font-family: Arial;
            background: #0e0e0e;
            color: white;
            padding: 30px;
        }

        h1 {
            color: #ff6a00;
        }

        .day {
            margin-bottom: 25px;
            padding: 15px;
            background: #1a1a1a;
            border-radius: 10px;
        }

        .battle {
            margin: 8px 0;
            padding: 10px;
            background: #262626;
            border-radius: 6px;
        }

        a {
            color: orange;
            text-decoration: none;
        }

        .logout {
            float: right;
        }
    </style>
</head>

<body>

<h1>
🔥 Ember Empire Dashboard
<a class="logout" href="/logout">Logout</a>
</h1>

<% if (!week) { %>
    <p>No schedule data found.</p>
<% } else { %>

    <% Object.keys(week).forEach(day => { %>

        <div class="day">
            <h2><%= day %></h2>

            <% if (!week[day] || week[day].length === 0) { %>

                <p>No battles scheduled</p>

            <% } else { %>

                <% week[day].forEach(battle => { %>

                    <div class="battle">

                        <strong>
                            <%= battle.host || "Unknown Host" %>
                            vs
                            <%= battle.opponent || "Unknown Opponent" %>
                        </strong>

                        <br>

                        Date:
                        <%= battle.date || "Unknown" %>

                        Time:
                        <%= battle.time || "Unknown" %>

                        <% if (battle.liveLink) { %>
                            <br>
                            <a href="<%= battle.liveLink %>" target="_blank">
                                Watch Live
                            </a>
                        <% } %>

                    </div>

                <% }) %>

            <% } %>

        </div>

    <% }) %>

<% } %>

</body>
</html>